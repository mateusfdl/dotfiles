[env]
MISE_GO_DEFAULT_PACKAGES_FILE = "~/.config/mise/default-packages/go"
MISE_LUA_DEFAULT_PACKAGES_FILE = "~/.config/mise/default-packages/lua"
MISE_RUBY_DEFAULT_PACKAGES_FILE = "~/.config/mise/default-packages/ruby"
MISE_NODE_DEFAULT_PACKAGES_FILE = "~/.config/mise/default-packages/node"
MISE_RUST_DEFAULT_PACKAGES_FILE = "~/.config/mise/default-packages/rust"

[tools]
python = "stable"
go = "latest"
node = "24.14.1"
rust = "stable"
lua = "latest"
zig = "latest"
k6 = "latest"
bun = "latest"
"aqua:go-task/task" = "latest"
"cargo:zola" = { git = "https://github.com/getzola/zola" }


{{ if eq .chezmoi.os "linux" }}
cmake = "latest"
clang-format = "latest"
java = "21"
{{ end }}

{{ if eq .chezmoi.os "darwin" }}
swift = "latest"
swiftformat = "latest"
swiftgen = "latest"
swiftlint = "latest"
tuist = "4.24.0"
fzf = "latest"
ruby = "latest"
opam = "latest"
chezmoi = "latest"
pnpm = "latest"
lazygit = "latest"
stylua = "latest"
neovim = "latest"
flutter = "latest"
{{ end }}

[settings]
go_set_gobin = true

[settings.node]
compile = false
