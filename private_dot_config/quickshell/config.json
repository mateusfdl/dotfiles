{
    "audio": {
        "protection": {
            "enable": false,
            "maxAllowed": 99,
            "maxAllowedIncrease": 10
        }
    },
    "bar": {
        "iconColor": "#ffffff",
        "margins": 15,
        "showBackground": false,
        "tray": {
            "iconSize": 20,
            "itemSize": 24,
            "spacing": 14
        }
    },
    "font": {
        "family": {
            "codeFont": "JetBrains Mono NF",
            "iconFont": "Maple Mono NF",
            "uiFont": "Open Sans"
        },
        "pixelSize": {
            "textBase": 15,
            "textLarge": 19,
            "textSmall": 13
        }
    },
    "hacks": {
        "arbitraryRaceConditionDelay": 20
    },
    "launcher": {
        "maxShown": 7,
        "sizes": {
            "itemHeight": 36
        }
    },
    "lock": {
        "blur": {
            "radius": 100
        },
        "launchOnStartup": false,
        "showLockedText": true
    },
    "modules": {
        "dailyTodos": true,
        "launcher": true,
        "lockScreen": true,
        "notifications": true,
        "obsidianTodo": true,
        "overview": true,
        "topbar": true,
        "wallpaper": true,
        "windowSwitcher": true
    },
    "sqlite": {
        "dbDir": "~/.local/state/quickshell",
        "dbName": "quickshell.db",
        "migrationsDir": "~/.config/quickshell/migrations"
    },
    "overview": {
        "previewRefreshInterval": 500,
        "scale": 0.15,
        "windowPadding": 6,
        "workspaceNumberSize": 220
    },
    "time": {
        "format": "hh:mm",
        "pomodoro": {
            "breakTime": 300,
            "cyclesBeforeLongBreak": 4,
            "focus": 1500,
            "longBreak": 900
        }
    },
    "ui": {
        "theme": "dark"
    }
}
