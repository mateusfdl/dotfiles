#!/bin/sh

unalias z 2> /dev/null

z() {
  [ $# -gt 0 ] && _z "$*" && return
  cd "$(_z -l 2>&1 | fzf --height 40% --nth 2.. --reverse --inline-info +s --tac --query "${*##-* }" | sed 's/^[0-9,.]* *//')"
}

japad() {
    if [ $# -lt 1 ]; then
        echo "Usage: japad <directory_path>"
        return 1
    fi

    directory_path="$1"
    file_paths=$(find "$directory_path" -type f -name "*.spec.ts" -exec printf "%s," {} \;)

    echo "$directory_path"

    if [ -z "$file_paths" ]; then
        echo "No .spec.ts files found in the specified directory."
        return 1
    fi

    node --prof -r ts-node/register japa/test.ts --files="${file_paths%,}"
}

resize(){
  tmux resize-pane -y $1 -t $2
}


grl() {
  git log --graph --color=always \
    --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" |
  fzf --ansi --no-sort --reverse --tiebreak=index \
    --prompt="git log > " \
    --bind=ctrl-s:toggle-sort \
    --preview='echo {} | grep -o "[a-f0-9]\{7\}" | head -1 | xargs -I % git show --color=always %' \
    --preview-window=right:50% \
    --tmux 80% |
  grep -o '[a-f0-9]\{7\}' | head -1 | xargs git rev-parse
}

gdf() {
  git diff --name-status "$@" |
  fzf --ansi --no-sort --reverse --tiebreak=index \
    --prompt="git diff > " \
    --bind=ctrl-s:toggle-sort \
    --preview='echo {} | awk "{print \$2}" | xargs git diff --color=always "$@" --' \
    --preview-window=right:50% \
    --tmux 80% |
  awk '{print $2}' | xargs -r nvim
}

on() {
  nvim -c ":ObsidianNew $*" -c "ObsidianTemplate notes"
}

detect_os() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        if [ -n "$(command -v wsl.exe)" ] || [ -f /proc/sys/fs/binfmt_misc/WSLInterop ]; then
            echo "wsl"
        else
            echo "linux"
        fi
    else
        echo "unknown"
    fi
}

is_arch() {
  if [ "$(detect_os)" = "linux" ]; then
    if [ -f /etc/arch-release ]; then
      return 0
    fi
  fi
  return 1
}

zlaude() {
  export ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
  export ANTHROPIC_AUTH_TOKEN=$(echo $Z_AI_API_KEY)
  claude "$@"
}

open() {
  if is_arch; then
    if command -v nautilus >/dev/null 2>&1; then
      nautilus "$@" &
    else
      return 1
    fi
  else
    return 1
  fi
}

pclaude() {
  CLAUDE_CONFIG_DIR="$HOME/.claude-personal/" claude "$@"
}

rsclaude() {
  CLAUDE_CONFIG_DIR="$HOME/.claude-runsmith/" claude "$@"
}

ccusage() {
  case "${1:-}" in
    --from=today|--from=week|--from=month)
      python - "$1" <<'PY'
import datetime
import json
import pathlib
import subprocess
import sys


def die(message):
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(1)


def compact_duration(milliseconds):
    seconds = int(milliseconds / 1000)
    hours = seconds // 3600
    minutes = (seconds % 3600) // 60
    remaining_seconds = seconds % 60
    return f"{hours}h {minutes}m {remaining_seconds}s"


def project_session_path(project_path, session_id):
    encoded_project = project_path.strip("/").replace("/", "-")
    return pathlib.Path.home() / ".claude" / "projects" / encoded_project / f"{session_id}.jsonl"


def session_last_timestamp(session_path):
    last_timestamp = None
    with session_path.open(encoding="utf-8") as session_file:
        for line in session_file:
            try:
                record = json.loads(line)
            except json.JSONDecodeError:
                continue

            timestamp = record.get("timestamp")
            if timestamp is None:
                continue

            current = datetime.datetime.fromisoformat(timestamp.replace("Z", "+00:00")).astimezone()
            if last_timestamp is None or current > last_timestamp:
                last_timestamp = current

    return last_timestamp


period = sys.argv[1].split("=", 1)[1]
now = datetime.datetime.now().astimezone()

if period == "today":
    start = now.replace(hour=0, minute=0, second=0, microsecond=0)
elif period == "week":
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)
    start = today_start - datetime.timedelta(days=today_start.weekday())
elif period == "month":
    start = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
else:
    die("expected --from=today, --from=week, or --from=month")

since = start.strftime("%Y%m%d")
until = now.strftime("%Y%m%d")

result = subprocess.run(
    ["bunx", "ccusage", "claude", "daily", "--since", since, "--until", until, "--json"],
    check=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
    text=True,
)
usage = json.loads(result.stdout)
total_cost = usage.get("totals", {}).get("totalCost", 0)

state_path = pathlib.Path.home() / ".claude.json"
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    die("~/.claude.json was not found")

duration_ms = 0
for project_path, project in state.get("projects", {}).items():
    session_id = project.get("lastSessionId")
    if session_id is None:
        continue

    path = project_session_path(project_path, session_id)
    if not path.exists():
        matches = list((pathlib.Path.home() / ".claude" / "projects").rglob(f"{session_id}.jsonl"))
        if len(matches) == 0:
            continue
        path = matches[0]

    last_timestamp = session_last_timestamp(path)
    if last_timestamp is None:
        continue

    if start <= last_timestamp <= now:
        duration_ms += project.get("lastAPIDuration", 0)

print(f"Total cost:             ${total_cost:,.2f}")
print(f"Total duration (API):   {compact_duration(duration_ms)}")
PY
      ;;
    --from=*)
      printf '%s\n' "Usage: ccusage --from=today|week|month" >&2
      return 1
      ;;
    *)
      bunx ccusage "$@"
      ;;
  esac
}

scripts() {
  echo "z - jump to a directory"
  echo "japad - run japa tests for a directory"
  echo "resize - resize a tmux pane"
  echo "grl - git log with fzf"
  echo "gdf - git diff files with fzf"
  echo "on - create a new obsidian note"
  echo "open - alias for nautilus in NixOS"
  echo "zlaude - claude with Z"
  echo "ccusage --from=today|week|month - compact Claude usage cost and API duration"
}
